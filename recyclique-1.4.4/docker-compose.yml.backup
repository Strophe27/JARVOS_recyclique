services:
  postgres:
    image: postgres:15
    environment:
      POSTGRES_DB: ${POSTGRES_DB}
      POSTGRES_USER: recyclic
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U recyclic"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - recyclic-network

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - recyclic-network

  api:
    build:
      context: ./api
      args:
        APP_VERSION: ${APP_VERSION:-$(./scripts/get-version.sh)}
        COMMIT_SHA: ${COMMIT_SHA:-unknown}
        BRANCH: ${BRANCH:-unknown}
        COMMIT_DATE: ${COMMIT_DATE:-unknown}
        BUILD_DATE: ${BUILD_DATE:-unknown}
    image: recyclic-api:${API_IMAGE_TAG:-latest}
    command: uvicorn recyclic_api.main:app --host 0.0.0.0 --port 8000 --reload
    environment:
      DATABASE_URL: postgresql://recyclic:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      REDIS_URL: redis://redis:6379
      SECRET_KEY: ${SECRET_KEY}
      ENVIRONMENT: ${ENVIRONMENT:-development}
      TESTING: "true"
      HOST: 0.0.0.0
      ALLOWED_HOSTS: ${ALLOWED_HOSTS:-localhost,127.0.0.1}
      CORS_ALLOW_ORIGINS: ${CORS_ALLOW_ORIGINS:-http://localhost:4444}
      BACKEND_CORS_ORIGINS: ${BACKEND_CORS_ORIGINS:-http://localhost:4444}
      FRONTEND_URL: ${FRONTEND_URL:-http://localhost:4444}
      API_V1_STR: ${API_V1_STR:-/v1}
      ROOT_PATH: ${ROOT_PATH:-}
      # Email Service (Brevo)
      BREVO_API_KEY: ${BREVO_API_KEY}
      BREVO_WEBHOOK_SECRET: ${BREVO_WEBHOOK_SECRET}
      EMAIL_FROM_NAME: ${EMAIL_FROM_NAME}
      EMAIL_FROM_ADDRESS: ${EMAIL_FROM_ADDRESS}
      # Variables pour Alembic migrations
      POSTGRES_HOST: postgres
      POSTGRES_USER: recyclic
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_PORT: 5432
      POSTGRES_DB: recyclic
    ports:
      - "${API_PORT:-8000}:8000"
    volumes:
      - ./api/src:/app/src
      - ./api/tests:/app/tests:ro
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 30s
    networks:
      - recyclic-network

  # BOT SERVICE DISABLED (STORY-B36-P3)
  # bot:
  #   build: ./bot
  #   image: recyclic-bot:${BOT_IMAGE_TAG:-latest}
  #   environment:
  #     DATABASE_URL: postgresql://recyclic:${POSTGRES_PASSWORD}@postgres:5432/recyclic
  #     REDIS_URL: redis://redis:6379
  #     TELEGRAM_BOT_TOKEN: ${TELEGRAM_BOT_TOKEN}
  #     API_BASE_URL: http://api:8000
  #     FRONTEND_URL: ${FRONTEND_URL:-http://localhost:4444}
  #     ADMIN_TELEGRAM_IDS: ${ADMIN_TELEGRAM_IDS}
  #     ENABLE_INLINE_BUTTONS: ${ENABLE_INLINE_BUTTONS:-true}
  #   depends_on:
  #     postgres:
  #       condition: service_healthy
  #     redis:
  #       condition: service_healthy
  #     api:
  #       condition: service_healthy
  #   healthcheck:
  #     test: ["CMD", "curl", "-f", "http://localhost:8001/health"]
  #     interval: 30s
  #     timeout: 10s
  #     retries: 3
  #   networks:
  #     - recyclic-network

  # Service dédié pour les migrations Alembic avec configuration Docker optimisée
  api-migrations:
    build:
      context: ./api
      dockerfile: Dockerfile.migrations
    image: recyclic-api-migrations:${API_MIGRATIONS_IMAGE_TAG:-latest}
    command: alembic upgrade head
    environment:
      DATABASE_URL: postgresql://recyclic:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}
      REDIS_URL: redis://redis:6379
      SECRET_KEY: ${SECRET_KEY}
      ENVIRONMENT: ${ENVIRONMENT:-development}
      API_V1_STR: ${API_V1_STR:-/v1}
      ROOT_PATH: ${ROOT_PATH:-}
      # Variables pour Alembic migrations
      POSTGRES_HOST: postgres
      POSTGRES_USER: recyclic
      POSTGRES_PASSWORD: ${POSTGRES_PASSWORD}
      POSTGRES_PORT: 5432
      POSTGRES_DB: recyclic
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
    networks:
      - recyclic-network
    restart: "no"

  # # Service dédié pour les tests avec volumes pour développement rapide
