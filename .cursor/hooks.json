{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": "cmd /c python .cursor/hooks/cursor_hooks_diagnostic.py"
      }
    ],
    "beforeSubmitPrompt": [
      {
        "command": "cmd /c python .cursor/hooks/log_before_submit_prompt.py"
      }
    ],
    "afterAgentResponse": [
      {
        "command": "cmd /c python .cursor/hooks/log_after_agent_orchestrator.py"
      }
    ]
  }
}
