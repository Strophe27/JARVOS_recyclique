# RecyClique — Variables d'environnement (exemple)
# Copier vers .env et renseigner les valeurs. Ne pas versionner .env (secrets).
# Référence : README, doc/deployment.md, doc/canal-push.md

# ------------------------------------------------------------------------------
# Base de données (RecyClique)
# ------------------------------------------------------------------------------
# DATABASE_URL=postgresql://recyclic:MOT_DE_PASSE@postgres:5432/recyclic

# ------------------------------------------------------------------------------
# Redis (EventBus, file push Paheko)
# ------------------------------------------------------------------------------
# REDIS_URL=redis://redis:6379/0

# ------------------------------------------------------------------------------
# JWT (auth API — NFR-S2)
# ------------------------------------------------------------------------------
# JWT_SECRET_KEY=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
# JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ------------------------------------------------------------------------------
# Canal push Paheko (worker Redis Streams — Story 4.1, NFR-S1, NFR-S2)
# Requis pour que le worker envoie les tickets vers Paheko.
# ------------------------------------------------------------------------------
# URL du plugin Paheko (ex. https://paheko.example/plugin/recyclic/push)
# PAHEKO_PLUGIN_URL=https://paheko.example/plugin/recyclic/push
# Secret partagé (ne pas mettre de valeur par défaut en prod)
# PAHEKO_PLUGIN_SECRET=

# Résilience (FR19) : tentatives et backoff
# PAHEKO_PUSH_MAX_RETRIES=5
# PAHEKO_PUSH_BACKOFF_SECONDS=1.0
# PAHEKO_PUSH_BACKOFF_FACTOR=2.0

# Nom du stream Redis pour la file push caisse (Story 4.2, défaut : recyclic:push:caisse)
# REDIS_STREAM_PUSH_CAISSE=recyclic:push:caisse

# ------------------------------------------------------------------------------
# OIDC / IdP (Story 12.2, Story 14.1)
# ------------------------------------------------------------------------------
# Activer le flux SSO BFF (Authorization Code + PKCE)
# OIDC_ENABLED=false
#
# Issuer OIDC (endpoint metadata discovery):
# ex. https://idp-dev.recyclique.local/realms/recyclique-dev
# OIDC_ISSUER=
#
# Client OIDC RecyClique (BFF)
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
#
# Redirect URI callback BFF (doit correspondre exactement au client IdP)
# OIDC_REDIRECT_URI=https://recyclique-dev.example.org/v1/auth/sso/callback
#
# Audience optionnelle (si differente de client_id)
# OIDC_AUDIENCE=
#
# Scope minimal recommande
# OIDC_SCOPE=openid profile email
#
# Endpoints explicites (optionnels: sinon derives de OIDC_ISSUER)
# OIDC_AUTHORIZATION_ENDPOINT=
# OIDC_TOKEN_ENDPOINT=
# OIDC_JWKS_URI=
# OIDC_END_SESSION_ENDPOINT=
#
# Durcissement claims/validation
# OIDC_ALLOWED_ALGS_CSV=RS256
# OIDC_ALLOWED_TENANTS_CSV=
# OIDC_HTTP_TIMEOUT_SECONDS=10
# OIDC_FAIL_CLOSED_STRICT=true
#
# Cookie BFF en environnement HTTPS reel
# AUTH_SESSION_COOKIE_SECURE=true
# AUTH_SESSION_COOKIE_SAMESITE=lax
#
# Fail-closed strict runtime:
# - OIDC_ISSUER, OIDC_CLIENT_ID, OIDC_CLIENT_SECRET, OIDC_REDIRECT_URI requis si OIDC_ENABLED=true
# - OIDC_FAIL_CLOSED_STRICT doit rester a true
#
# IMPORTANT: ne jamais committer de valeurs reelles de secrets.
# Stocker OIDC_CLIENT_SECRET et credentials admin IdP dans un coffre de secrets
# (ou equivalent), puis injecter en runtime.
#
# ------------------------------------------------------------------------------
# Paheko OIDC (Story 14.2 - configuration client OIDC cote Paheko)
# Activation via /var/www/paheko/config.local.php (pas via UI).
# Callback exact attendu cote Paheko et IdP:
# http://localhost:8080/admin/login.php?oidc
# IMPORTANT: pas de fallback implicite dans config.local.php pour URL/client_id.
# Si les variables suivantes sont absentes/vides, le flux OIDC Paheko reste fail-closed.
# ------------------------------------------------------------------------------
# PAHEKO_OIDC_CLIENT_URL=http://host.docker.internal:8081/realms/recyclique-dev
# PAHEKO_OIDC_CLIENT_ID=paheko-web-dev
# PAHEKO_OIDC_CLIENT_SECRET=
# PAHEKO_OIDC_CLIENT_MATCH_EMAIL=true  # bool strict: true/false/1/0
# PAHEKO_TEST_MEMBER_EMAIL=oidc.test@local.dev
# PAHEKO_TEST_MEMBER_NAME=OIDC Test User
#
# Keycloak local dev (service docker-compose `keycloak`)
# KEYCLOAK_ADMIN_USER=admin
# KEYCLOAK_ADMIN_PASSWORD=admin
#
# ------------------------------------------------------------------------------
# Docker Compose (optionnel, utilisé par postgres)
# ------------------------------------------------------------------------------
# POSTGRES_PASSWORD=recyclic
